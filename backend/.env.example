# --- API Server ---
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# --- API Authentication ---
# Set this to a strong random secret (>= 16 chars) in production. When
# unset, the API is open (dev / emulator mode only). The frontend
# reads VITE_API_KEY at build time and sends it as `X-Api-Key`.
API_KEY=

# --- CORS ---
# Comma-separated list of allowed origins. Leave empty in dev for a
# permissive CORS; in production set this to your real frontend origin
# e.g. ALLOWED_ORIGINS=https://app.example.com
ALLOWED_ORIGINS=

# --- Redis (BullMQ) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Firebase Emulator (demo / docker) ---
FIREBASE_AUTH_EMULATOR_HOST=firebase-emulator:9099
FIRESTORE_EMULATOR_HOST=firebase-emulator:8080
FIREBASE_STORAGE_EMULATOR_HOST=firebase-emulator:9199
FIREBASE_PROJECT_ID=demo-image-pipeline

# --- Firebase Production (uncomment + provide creds to use real Firebase) ---
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# --- Worker tuning ---
WORKER_CONCURRENCY=4
JOB_MAX_IMAGE_BYTES=10485760   # 10 MB max source image
JOB_DOWNLOAD_TIMEOUT_MS=20000
JOB_HARD_TIMEOUT_MS=120000    # end-to-end per-job timeout

# --- Data retention ---
JOB_TTL_HOURS=24              # Firestore records older than this are swept
STORAGE_TTL_HOURS=24          # Result files older than this are swept
