# Backend URL used in the browser when the Vite dev server proxies /api
VITE_API_URL=http://localhost:3100

# Firebase JS SDK config (frontend uses these to talk to Firestore emulator)
VITE_FIREBASE_PROJECT_ID=demo-image-pipeline
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-image-pipeline.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=demo-image-pipeline.appspot.com

# Emulator hosts (browser-accessible — localhost, NOT the docker service name)
# Must match the host-side port mappings in docker-compose.yml.
VITE_FIREBASE_AUTH_EMULATOR_HOST=localhost:9095
VITE_FIRESTORE_EMULATOR_HOST=localhost:8085
VITE_FIREBASE_STORAGE_EMULATOR_HOST=localhost:9200
